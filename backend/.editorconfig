root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{kt,kts}]
# ktlintの整形スタイル。IntelliJ既定に近い intellij_idea を用いてchurnを抑える。
ktlint_code_style = intellij_idea
# 日本語コメント行が長くなるため行長ルールは無効化（意味のある折返しは手動で行う）。
ktlint_standard_max-line-length = disabled
# ヘキサゴナルの adapter.in.* パッケージは `in`（Kotlin予約語）をバッククォート必須とするため、
# package-name ルールが誤検知する。設計上の正当な命名なので無効化する。
ktlint_standard_package-name = disabled
# 関連する宣言を1ファイルへまとめる方針（例: PaymentQueries.kt）を採るため filename ルールは無効化。
ktlint_standard_filename = disabled
